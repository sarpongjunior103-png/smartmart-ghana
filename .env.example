# ===========================================
# SmartMart Ghana — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ===== Application =====
NEXT_PUBLIC_SITE_URL=https://smartmartghana.com
NEXT_PUBLIC_SITE_NAME=SmartMart Ghana
NEXT_PUBLIC_CONTACT_PHONE=+233 55 162 1261
NEXT_PUBLIC_CONTACT_EMAIL=smrtmart304@gmail.com
NODE_ENV=production

# ===== Supabase (Database & Auth) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://user:pass@host:5432/dbname

# ===== Payment Gateways =====

# Hubtel
HUBTEL_CLIENT_CODE=your-hubtel-client-code
HUBTEL_SECRET=your-hubtel-secret

# Paystack
PAYSTACK_SECRET_KEY=sk_live_or_test_your-key
PAYSTACK_PUBLIC_KEY=pk_live_or_test_your-key

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK-your-key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your-key
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-your-encryption-key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===== Email Service (Resend) =====
EMAIL_API_KEY=re_your-resend-api-key
EMAIL_FROM=smrtmart304@gmail.com
EMAIL_FROM_NAME=SmartMart Ghana

# ===== SMS Service (Arkesel) =====
SMS_API_KEY=your-arkesel-api-key
SMS_SENDER_ID=SmartMart

# ===== Cloudinary (File Storage) =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ===== Push Notifications =====
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ===== Security =====
JWT_SECRET=your-jwt-secret-min-32-chars
CSRF_SECRET=your-csrf-secret-min-32-chars
ENCRYPTION_KEY=your-encryption-key-32-chars

# ===== Monitoring =====
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
LOGDNA_API_KEY=your-logdna-key

# ===== Rate Limiting =====
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ===== Admin =====
ADMIN_EMAIL=smrtmart304@gmail.com

# ===== AI Assistant (OpenAI) =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ===== Optional: Neon PostgreSQL (alternative DB) =====
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
